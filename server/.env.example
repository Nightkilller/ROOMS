PORT=5001
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/rooms?retryWrites=true&w=majority

ACCESS_TOKEN_SECRET=replace_with_random_64char_hex
REFRESH_TOKEN_SECRET=replace_with_random_64char_hex

CLIENT_URL=http://localhost:5173

# Email — Gmail + App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16char_app_password
SMTP_FROM="ROOMS <noreply@rooms.app>"

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback
